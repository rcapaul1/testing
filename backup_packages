#!/bin/bash

# Datei, in der die Paketliste gespeichert wird
OUTPUT_FILE="installed_packages.txt"
OS_TYPE="unknown"

echo "Starte Analyse der installierten Programme..."

# Distribution erkennen und Pakete exportieren
if [ -f /etc/arch-release ]; then
    OS_TYPE="arch"
    echo "Arch Linux erkannt."
    # -Qqe liefert explizit installierte Pakete
    pacman -Qqe > "$OUTPUT_FILE"
    
elif [ -f /etc/debian_version ] || [ -f /etc/lsb-release ]; then
    OS_TYPE="ubuntu"
    echo "Ubuntu/Debian-basiertes System erkannt."
    # liefert nur die manuell installierten Pakete ohne automatische Abhängigkeiten
    apt-mark showmanual > "$OUTPUT_FILE"
    
elif [ -f /etc/redhat-release ]; then
    OS_TYPE="redhat"
    echo "RedHat/Fedora/CentOS erkannt."
    # dnf/rpm exportiert die Paketnamen
    rpm -qa --qf "%{NAME}\n" > "$OUTPUT_FILE"
fi

if [ "$OS_TYPE" != "unknown" ]; then
    echo "Erfolgreich! Die Programme wurden in '$OUTPUT_FILE' gespeichert."
    echo "Sichere diese Datei für die Neuinstallation."
else
    echo "Fehler: Distribution konnte nicht eindeutig identifiziert werden."
    exit 1
fi
